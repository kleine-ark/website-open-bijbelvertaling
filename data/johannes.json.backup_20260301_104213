        {
          "number": 7,
          "ref": "bibjoha013:07",
          "text1637": "Iesus antwoordde ende seyde tot hem, [12] Dat ick doe en weet ghy nu niet, maer ghy sult het [13] na desen verstaen.",
          "text1637_html": "Iesus antwoordde ende seyde tot hem, <sup class=\"note-marker\" data-note=\"12\">12</sup> Dat ick doe en weet ghy nu niet, maer ghy sult het <sup class=\"note-marker\" data-note=\"13\">13</sup> na desen verstaen.",
          "marginNotes": [
            {
              "marker": "12",
              "type": "explanatory",
              "text1637": "D. waerom ick sulcks doe."
            },
            {
              "marker": "13",
              "type": "explanatory",
              "text1637": "N. als ick het u sal verklaert hebben, gelijck hy doet vers 13, 14."
            }
