              "type": "crossref",
              "text1637": "Ioan. 15.3."
            },
            {
              "marker": "17",
              "type": "explanatory",
              "text1637": "D. gereynight door my van de sonde, ende heerschappye der selve. Ro. 6.11, 12."
            }
